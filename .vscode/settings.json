{
  "files.autoSave": "afterDelay",
  "files.eol": "\n",
  "explorer.compactFolders": false,
  "editor.tabSize": 2,
  "editor.inlayHints.fontSize": 10,
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.linkedEditing": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [{ "scope": ["entity.name.tag"], "settings": { "foreground": "#4FC1FF" } }] // Tô màu tag trong vue template
  },
  "window.title": "${rootName}",
  "workbench.colorCustomizations": {
    "editorInlayHint.background": "#4d4d4d99",
    "editorInlayHint.foreground": "#ffffffcc"
  },
  "workbench.editor.enablePreview": false,
  "workbench.editor.wrapTabs": true,
  "workbench.tree.indent": 16,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "search.smartCase": true,
  "search.exclude": {
    "docs/**": true,
    "dist/**": true
  },
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.format.semicolons": "remove",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.preferences.importModuleSpecifierEnding": "minimal", // Import bỏ index.ts
  "git.allowForcePush": true,
  "eslint.validate": ["javascript", "javascriptreact", "vue"],
  "cSpell.language": "en,vi",
  "cSpell.words": [
    "antd",
    "Appstore",
    "Axios",
    "CĐHA",
    "chartjs",
    "colspan",
    "contenteditable",
    "Dexie",
    "ICDDB",
    "Medihome",
    "oneline",
    "pinia",
    "tailwindcss",
    "tinymce",
    "Upserted",
    "viettelpost",
    "vuejs",
    "zalo"
  ],
  "vue.autoInsert.dotValue": true,
  "vue.complete.casing.props": "autoCamel"
}
